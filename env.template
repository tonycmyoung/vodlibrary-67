# =============================================================================
# TY Kobudo Library - Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
#
# For v0/Vercel deployment, set these in the Vercel dashboard under
# Project Settings → Environment Variables.
# =============================================================================

# =============================================================================
# SUPABASE CONFIGURATION (Required)
# =============================================================================
# Get these from your Supabase project dashboard:
# Project Settings → API → Project URL and API Keys

# The full URL to your Supabase project (e.g., https://xxxxx.supabase.co)
SUPABASE_URL=

# Service role key - NEVER expose on client side, server-only
# Has full access to bypass Row Level Security
SUPABASE_SERVICE_ROLE_KEY=

# Anonymous key - safe for client-side use, respects RLS
SUPABASE_ANON_KEY=

# Public Supabase URL - used in client-side code
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key - used in client-side code
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# JWT secret for token verification (Project Settings → API → JWT Settings)
SUPABASE_JWT_SECRET=

# =============================================================================
# EMAIL CONFIGURATION - RESEND (Required for email features)
# =============================================================================
# Sign up at https://resend.com and create an API key

# Your Resend API key (starts with re_)
RESEND_API_KEY=

# The email address to send FROM (must be verified in Resend)
# Use format: noreply@yourdomain.com
FROM_EMAIL=

# Admin email for receiving system notifications (new user registrations, etc.)
ADMIN_EMAIL=

# =============================================================================
# FILE STORAGE - VERCEL BLOB (Required for profile images)
# =============================================================================
# Create a Blob store in Vercel dashboard and get the token

BLOB_READ_WRITE_TOKEN=

# =============================================================================
# APPLICATION URLS (Required)
# =============================================================================

# Production site URL - the canonical URL for your live site
# Used in emails (footer links, signup invitations) and user-facing navigation
# This should ALWAYS point to your production domain, even in preview deployments
# Example: https://yourdomain.com
NEXT_PUBLIC_FULL_SITE_URL=https://yourdomain.com

# Deployment URL - the URL of the current deployment
# Used for Supabase auth callback redirects (/auth/confirm/callback)
# In production: same as NEXT_PUBLIC_FULL_SITE_URL
# In preview/staging: the preview deployment URL (e.g., https://preview-xxx.vercel.app)
# For local dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Development-specific Supabase redirect URL (optional)
# If set, overrides NEXT_PUBLIC_SITE_URL for auth callbacks in development
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=

# =============================================================================
# ADMIN CONFIGURATION (Required)
# =============================================================================
# Super admin login email - the email address used to sign in as the super admin
# This user will have admin privileges regardless of database role
# Used for initial setup and emergency access
ADMIN_USER=

# =============================================================================
# STRIPE CONFIGURATION (Optional - for subscriptions/donations)
# =============================================================================
# Get these from https://dashboard.stripe.com/apikeys
#
# IMPORTANT: Use Stripe TEST mode keys (sk_test_*, pk_test_*) for development
# and preview environments. Only use LIVE mode keys (sk_live_*, pk_live_*) in
# production to avoid processing real payments during testing.

# Secret key (server-side only)
# Test mode: starts with sk_test_
# Live mode: starts with sk_live_
STRIPE_SECRET_KEY=

# Publishable key (client-side safe)
# Test mode: starts with pk_test_
# Live mode: starts with pk_live_
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Subscription price IDs (from Stripe Products)
# Use TEST mode price IDs (price_*) for development/preview environments
# Use LIVE mode price IDs for production only
NEXT_PUBLIC_SUPPORTER_MONTHLY_PRICE_ID=
NEXT_PUBLIC_SUPPORTER_ANNUAL_PRICE_ID=
NEXT_PUBLIC_PATRON_MONTHLY_PRICE_ID=
NEXT_PUBLIC_PATRON_ANNUAL_PRICE_ID=
NEXT_PUBLIC_CHAMPION_MONTHLY_PRICE_ID=
NEXT_PUBLIC_CHAMPION_ANNUAL_PRICE_ID=

# =============================================================================
# DONATIONS (Optional)
# =============================================================================
# PayID displayed in donation modal (Australian bank transfer)
NEXT_PUBLIC_DONATE_PAYID=
